{
  "app": "python3 app.py",
  "watch": {
    "include": ["**"],
    "exclude": [
      "README.md",
      "cdk*.json",
      "**/__pycache__/**",
      "**/.venv/**"
    ]
  },
  "context": {
    "@aws-cdk/aws-apigateway:usagePlanKeyOrderInsensitiveId": true,
    "@aws-cdk/aws-lambda:recognizeLayerVersion": true,
    "@aws-cdk/aws-cloudfront:defaultSecurityPolicyTLSv1.2_2021": true,

    "githubOwner": "taiki-koyama",
    "githubRepo": "cancha",
    "codestarConnectionArn": "arn:aws:codestar-connections:ap-northeast-1:YOUR_ACCOUNT_ID:connection/XXXXXXXX",

    "ecrRepoName": "soccer-app-backend",
    "frontendBucketName": "soccer-app-frontend-YOUR_ACCOUNT_ID",
    "ecsClusterName": "soccer-app-cluster",
    "ecsServiceName": "soccer-app-service",
    "cfDistributionId": "XXXXXXXXXXXX"
  }
}
